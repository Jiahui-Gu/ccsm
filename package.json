{
  "name": "ccsm",
  "version": "0.2.0",
  "description": "CCSM (Claude Code Session Manager) — group-first manager for many Claude Code sessions",
  "productName": "CCSM",
  "license": "MIT",
  "author": {
    "name": "Jiahui Gu",
    "email": "noreply@ccsm.dev"
  },
  "homepage": "https://github.com/Jiahui-Gu/ccsm",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jiahui-Gu/ccsm.git"
  },
  "main": "dist/electron/main.js",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "ws:install": "pnpm install",
    "ws:build": "pnpm -r run build",
    "ws:test": "pnpm -r run test",
    "ws:lint": "pnpm -r run lint",
    "dev": "concurrently -k -n web,app -c blue,magenta \"npm:dev:web\" \"npm:dev:app\"",
    "dev:web": "webpack serve --config webpack.config.js --mode development",
    "dev:app": "wait-on http://localhost:4100 && tsc -p tsconfig.electron.json && electron .",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "gen": "turbo run gen",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "build:app": "npm run clean && npm run prebuild:app && tsc -p tsconfig.electron.json && webpack --mode production && node -e \"const fs=require('fs');const p='dist/renderer/bundle.js';const t=Date.now()/1000;fs.utimesSync(p,t,t)\"",
    "prebuild:app": "node scripts/gen-proto.mjs",
    "test:app": "vitest run",
    "lint:app": "eslint . --ext .ts,.tsx",
    "lint:no-ipc": "bash tools/lint-no-ipc.sh",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.electron.json",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "probe:e2e": "npm run build:app && node scripts/run-all-e2e.mjs",
    "make": "npm run build:app && electron-builder --publish never",
    "make:win": "npm run build:app && electron-builder --win --publish never",
    "make:win:dev": "npm run build:app && electron-builder --win --publish never --config.productName=\"CCSM Dev\" --config.extraMetadata.productName=\"CCSM Dev\" --config.appId=com.ccsm.app.dev --config.nsis.shortcutName=\"CCSM Dev\"",
    "make:mac": "npm run build:app && electron-builder --mac --publish never",
    "make:linux": "npm run build:app && electron-builder --linux --publish never",
    "build:icon": "electron scripts/build-icon.cjs",
    "postinstall": "node scripts/postinstall.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version && node scripts/sync-version.mjs",
    "release": "turbo run build && changeset publish",
    "proto-version-check": "pnpm --filter @ccsm/proto run version-drift-check",
    "check:engines": "node -e \"if(!process.version.startsWith('v22.'))console.warn('[warn] CI uses Node 22, you have '+process.version+'; native modules may need rebuild')\"",
    "check:native": "cd packages/daemon && node -e \"require('better-sqlite3')(':memory:').exec('select 1')\"",
    "rebuild:native": "npm rebuild better-sqlite3"
  },
  "engines": {
    "node": ">=22.0.0 <23"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.119",
    "@bufbuild/protobuf": "^2.12.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "@tanstack/react-query": "^5.62.0",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.4",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@sentry/electron": "7.11.0",
    "@sentry/react": "10.49.0",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/headless": "^5.5.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.0.0",
    "i18next": "^26.0.6",
    "lucide-react": "^0.469.0",
    "node-pty": "1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.4",
    "tailwind-merge": "^2.5.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.50.0",
    "@bufbuild/protoc-gen-es": "^2.2.3",
    "@changesets/cli": "^2.27.10",
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.0.0-beta.7",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "css-loader": "^7.1.2",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "html-webpack-plugin": "^5.6.3",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "postcss": "^8.4.49",
    "postcss-loader": "^8.1.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.2.0",
    "ts-loader": "^9.5.1",
    "turbo": "^2.5.8",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5",
    "wait-on": "^8.0.1",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0"
  },
  "build": {
    "appId": "com.ccsm.app",
    "productName": "CCSM",
    "copyright": "Copyright (c) 2026 Jiahui Gu",
    "npmRebuild": false,
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/node-pty/**"
    ],
    "afterPack": "scripts/after-pack.cjs",
    "files": [
      "dist/**/*",
      "package.json",
      "!**/*.map",
      "!**/*.ts",
      "!**/__tests__/**",
      "!**/tests/**"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Jiahui-Gu",
        "repo": "ccsm"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CCSM"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "maintainer": "Jiahui Gu <noreply@ccsm.dev>",
      "synopsis": "CCSM (Claude Code Session Manager) — group-first manager for many Claude Code sessions",
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}

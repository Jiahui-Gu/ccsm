{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "lib": ["ES2022"]
  },
  "include": [
    "daemon/**/*",
    "electron/sessionWatcher/**/*",
    "electron/security/ipcGuards.ts",
    "src/shared/**/*"
  ],
  "exclude": [
    "daemon/**/__tests__/**",
    "electron/sessionWatcher/**/__tests__/**"
  ]
}

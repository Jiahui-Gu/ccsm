{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": ["tsconfig.base.json", ".npmrc", "pnpm-lock.yaml"],
  "tasks": {
    "gen": {
      "outputs": ["gen/**"],
      "inputs": [
        "buf.yaml",
        "buf.gen.yaml",
        "ccsm/**/*.proto",
        "lock.json",
        "scripts/**"
      ]
    },
    "build": {
      "dependsOn": ["^build", "@ccsm/proto#gen"],
      "outputs": ["dist/**", "gen/**"],
      "inputs": [
        "src/**",
        "tsconfig.json",
        "tsconfig.*.json",
        "package.json",
        "build/**"
      ]
    },
    "test": {
      "dependsOn": ["^build", "@ccsm/proto#gen"],
      "outputs": [],
      "inputs": [
        "src/**",
        "test/**",
        "tests/**",
        "vitest.config.ts",
        "vitest.config.*.ts",
        "tsconfig.json",
        "tsconfig.*.json",
        "package.json"
      ]
    },
    "lint": {
      "outputs": [],
      "inputs": [
        "src/**",
        "test/**",
        "tests/**",
        "build/**",
        "eslint-plugins/**",
        "eslint.config.*",
        "package.json"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build", "@ccsm/proto#gen"],
      "outputs": [],
      "inputs": [
        "src/**",
        "test/**",
        "tsconfig.json",
        "tsconfig.*.json",
        "package.json"
      ]
    }
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ccsm-tauri",
  "version": "0.0.0",
  "identifier": "dev.ccsm.tauri",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ccsm-tauri",
        "width": 1100,
        "height": 750
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri:; connect-src 'self' ipc: http://127.0.0.1:* ws://127.0.0.1:*; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": ["icons/icon.ico"]
  }
}

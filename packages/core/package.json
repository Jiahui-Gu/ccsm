{
  "name": "@ccsm/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ws/client": {
      "types": "./dist/ws/client.d.ts",
      "import": "./dist/ws/client.js"
    },
    "./api/sessions": {
      "types": "./dist/api/sessions.d.ts",
      "import": "./dist/api/sessions.js"
    },
    "./runtime/session-runtime": {
      "types": "./dist/runtime/session-runtime.d.ts",
      "import": "./dist/runtime/session-runtime.js"
    },
    "./runtime/types": {
      "types": "./dist/runtime/types.d.ts",
      "import": "./dist/runtime/types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings=0",
    "test": "vitest run",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@ccsm/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}

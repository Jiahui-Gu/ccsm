exports[`visual snapshots — chrome components > ClaudeMissingGuide — recovery surface DOM is stable 1`] = `"<div class="flex h-screen w-screen items-center justify-center bg-neutral-950 px-6 text-neutral-100" data-testid="claude-missing-guide"><div class="w-full max-w-lg rounded-lg border border-neutral-800 bg-neutral-900 p-8 shadow-xl"><h1 class="text-lg font-semibold text-neutral-50">Claude CLI not found</h1><p class="mt-3 text-sm leading-relaxed text-neutral-300">ccsm requires the Claude CLI to be installed separately. Install it via npm and re-check.</p><div class="mt-5"><div class="text-xs uppercase tracking-wide text-neutral-500">Install command</div><code class="mt-2 block select-all rounded border border-neutral-800 bg-neutral-950 px-3 py-2 font-mono text-sm text-neutral-100" data-testid="claude-missing-install-command">npm install -g @anthropic-ai/claude-code</code></div><div class="mt-6 flex justify-end"><button type="button" class="rounded border border-neutral-700 bg-neutral-800 px-4 py-1.5 text-sm font-medium text-neutral-100 transition-colors hover:bg-neutral-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-neutral-400 disabled:cursor-not-allowed disabled:opacity-60" data-testid="claude-missing-recheck">Re-check</button></div></div></div>"`;

exports[`visual snapshots — chrome components > InstallerCorruptBanner — hidden when installerCorrupt=false 1`] = `""`;

exports[`visual snapshots — chrome components > InstallerCorruptBanner — shown when installerCorrupt=true 1`] = `"<div class="overflow-hidden" data-top-banner="" data-variant="error" data-testid="installer-corrupt-banner" style="opacity: 1; height: auto;"><div role="alert" aria-live="polite" class="flex items-center gap-2 px-3 py-2 border-b border-border-subtle bg-[oklch(0.3_0.11_25)] text-[oklch(0.95_0.06_25)]"><span class="shrink-0 inline-flex items-center"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-octagon-alert stroke-[2]"><path d="M12 16h.01"></path><path d="M12 8v4"></path><path d="M15.312 2a2 2 0 0 1 1.414.586l4.688 4.688A2 2 0 0 1 22 8.688v6.624a2 2 0 0 1-.586 1.414l-4.688 4.688a2 2 0 0 1-1.414.586H8.688a2 2 0 0 1-1.414-.586l-4.688-4.688A2 2 0 0 1 2 15.312V8.688a2 2 0 0 1 .586-1.414l4.688-4.688A2 2 0 0 1 8.688 2z"></path></svg></span><div class="flex-1 min-w-0 flex flex-col"><span class="text-meta font-semibold">Claude binary missing from this install</span><span class="text-meta truncate opacity-90 font-mono">CCSM ships the Claude binary inside the installer, but we couldn’t find it on disk. Please reinstall CCSM to repair the install — sessions can’t start until then.</span></div></div></div>"`;
